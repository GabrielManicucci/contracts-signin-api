generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContractStatus {
  DRAFT
  WAITING_FOR_SIGNATURE
  SIGNED
  EXPIRED
}

model Company {
  id        String   @id @default(uuid())
  name      String
  document  String?  @unique // CNPJ
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  contracts         Contract[]
  contractTemplates ContractTemplate[]
  obras             Obra[]

  @@map("companies")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id])

  @@map("users")
}

model ContractTemplate {
  id        String   @id @default(uuid())
  name      String
  category  String // ex: PRESTACAO_SERVICO, OBRA, LOCACAO
  content   String // The base HTML or JSON of the template
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company                 @relation(fields: [companyId], references: [id])
  fields    ContractTemplateField[]
  contracts Contract[]

  @@map("contract_templates")
}

model ContractTemplateField {
  id         String   @id @default(uuid())
  templateId String
  name       String // ex: "nome_contratante", "valor_mensal"
  type       String // ex: "text", "number", "date", "signature"
  label      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template ContractTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("contract_template_fields")
}

model Contract {
  id            String         @id @default(uuid())
  companyId     String
  templateId    String
  title         String
  status        ContractStatus @default(DRAFT)
  data          Json // Preenchimento dos campos dinâmicos do template
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  contractValue Decimal?       @db.Decimal(10, 2)

  company  Company          @relation(fields: [companyId], references: [id])
  template ContractTemplate @relation(fields: [templateId], references: [id])
  obras    Obra[]

  @@map("contracts")
}

model Obra {
  id         String   @id @default(uuid())
  companyId  String
  contractId String
  name       String
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  contract Contract @relation(fields: [contractId], references: [id])

  @@map("obras")
}
